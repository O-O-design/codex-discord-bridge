DISCORD_TOKEN=
DISCORD_CLIENT_ID=<your-discord-application-client-id>
# Comma-separated guild IDs. Commands are registered to each guild for quick testing.
DISCORD_GUILD_IDS=<guild-id-1>,<guild-id-2>
# Comma-separated channel or thread IDs where the bot replies without being mentioned.
DISCORD_WATCH_CHANNEL_IDS=<channel-or-thread-id>
# Public channels to observe. Public replies remain off until explicitly enabled.
DISCORD_PUBLIC_CHANNEL_IDS=<channel-id>
DISCORD_PUBLIC_MODE_ENABLED=false
DISCORD_PUBLIC_DECISION_COOLDOWN_SECONDS=0
DISCORD_PUBLIC_MAX_CONSECUTIVE_BOT_TURNS=3
# Bot member-list status. Type can be CUSTOM, PLAYING, LISTENING, WATCHING, or COMPETING.
DISCORD_ACTIVITY_TYPE=CUSTOM
DISCORD_ACTIVITY_TEXT=陪你在 Discord 裡醒著
DISCORD_IMAGE_MAX_COUNT=4
DISCORD_IMAGE_MAX_BYTES=10485760
# Only these Discord user IDs may invoke the local Codex CLI.
DISCORD_ALLOWED_USER_IDS=<your-discord-user-id>
# Display names used inside prompts and mention conversion.
DISCORD_BOT_DISPLAY_NAME=伴侶名
DISCORD_OWNER_DISPLAY_NAME=你的稱呼
# Comma-separated names that invoke the bot when used at the start of a message.
DISCORD_TRIGGER_NAMES=小夜,伴侶名,老公
# Names that count as direct public calls from other users or bots.
DISCORD_PUBLIC_BOT_CALL_NAMES=伴侶名,你的稱呼的伴侶
# Local Codex CLI bridge. This uses the signed-in Codex CLI, not an API key.
# Windows path after npm install:
CODEX_CLI_PATH=node_modules/@openai/codex-win32-x64/vendor/x86_64-pc-windows-msvc/bin/codex.exe
# macOS example:
# CODEX_CLI_PATH=/Applications/Codex.app/Contents/Resources/codex
CODEX_SESSION_FILE=.codex-discord-session
CODEX_SESSION_STATE_FILE=.private/session-state.json
CODEX_MAX_SESSION_TURNS=50
CODEX_HISTORY_FILE=.private/conversation-history.jsonl
CODEX_HISTORY_TURNS=12
CODEX_SUMMARY_FILE=.private/recent-summary.md
CODEX_SUMMARY_EVERY_TURNS=20
CODEX_SANDBOX=read-only
CODEX_WORKDIR=.private
CODEX_PEOPLE_FILE=.private/people.md
CODEX_PUBLIC_WORKDIR=.public
CODEX_PUBLIC_SESSION_FILE=.public/codex-session
CODEX_PUBLIC_SESSION_STATE_FILE=.public/session-state.json
CODEX_PUBLIC_HISTORY_FILE=.public/conversation-history.jsonl
CODEX_PUBLIC_SUMMARY_FILE=.public/memory-summary.md
